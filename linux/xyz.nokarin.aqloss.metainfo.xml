<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>xyz.nokarin.aqloss</id>
    <name>Aqloss</name>
    <summary>Audio, uncompromised.</summary>
    <description>
        <p>
            Aqloss is a music player built around a Rust audio engine, with optional WASAPI Exclusive mode on Windows for bit-perfect output to compatible hardware.
        </p>
    </description>

    <launchable type="desktop-id">xyz.nokarin.aqloss.desktop</launchable>

    <url type="homepage">https://www.nokarin.xyz/projects/aqloss</url>
    <url type="bugtracker">https://github.com/nokarin-dev/aqloss/issues</url>
    <url type="vcs-browser">https://github.com/nokarin-dev/aqloss</url>

    <developer_name>nokarin</developer_name>
    <developer id="xyz.nokarin">
        <name>nokarin</name>
    </developer>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>

    <supports>
        <control>pointing</control>
        <control>keyboard</control>
        <control>touch</control>
    </supports>

    <categories>
        <category>Audio</category>
    </categories>

    <branding>
        <color type="primary" scheme_preference="light">#8ed0e6</color>
        <color type="primary" scheme_preference="dark">#296275</color>
    </branding>

    <screenshots>
