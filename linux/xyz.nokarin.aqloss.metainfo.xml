            <caption>Library - Grid View</caption>
        </screenshot>
    </screenshots>

    <releases>
        <release version="0.3.0" date="2026-05-30">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.3.0</url>
            <description>
                <p>Added new features and improvements.</p>
                <ul>
                    <li>Added history screen</li>
                    <li>Added artist screen</li>
                    <li>Added queue panel</li>
                    <li>Added global search overlay</li>
                    <li>Added export &amp; import playlist</li>
                    <li>Fix settings navbar disappear on mobile</li>
                    <li>And more.</li>
                </ul>
            </description>
        </release>
        <release version="0.2.3" date="2026-05-26">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.2.3</url>
            <description>
                <p>Added media notifications, fix spacebar shortcut, and more.</p>
                <ul>
                    <li>Press scale animation to play button</li>
                    <li>Lrclib search &amp; get API fallback</li>
                    <li>Reopen output stream at native sample rate on load to avoid unnecessary resampling</li>
                    <li>Added hardware capability check in probe_exact_rate before opening streams</li>
                    <li>Fixed Spacebar shortcut being swallowed when search field is focused (migrated to HardwareKeyboard)</li>
                    <li>Added debounce guard (_playPauseBusy) to prevent backend freezes from play/pause spam</li>
                </ul>
            </description>
        </release>
        <release version="0.2.2" date="2026-05-19">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.2.2</url>
            <description>
                <p>Added helpers, fix discord button label overflow, cursor pointer, seek throttle, and more.</p>
                <ul>
                    <li>find button discord RPC now links to YouTube Music search</li>
                    <li>Call backend only on drag end to prevent seek throttle</li>
                    <li>All button now should has pointer now</li>
                    <li>Discord button label overflow</li>
                    <li>Added helpers to prevent backend crash</li>
                    <li>Added albums screen</li>
                </ul>
            </description>
        </release>
        <release version="0.2.1" date="2026-05-17">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.2.1</url>
            <description>
                <p>UI Adjusment, search fix, new theme, performance improvements, and more.</p>
                <ul>
                    <li>Aqloss logging</li>
                    <li>128-entry LRU cache for album art thumbnails</li>
                    <li>Grid / Detail view toggle in library</li>
                    <li>Islands themee</li>
                    <li>Now playing header on library and playlist</li>
                    <li>Mini player</li>
                    <li>Buffer underrun warning spam</li>
                    <li>Window not rounded on linux</li>
                    <li>Search doesn't work on library</li>
                    <li>And more.</li>
                </ul>
            </description>
        </release>
        <release version="0.2.0" date="2026-05-13">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.2.0</url>
            <description>
                <p>Fixed AOT library not found when app starts</p>
            </description>
        </release>
        <release version="0.1.1" date="2026-05-13">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.1.1</url>
            <description>
                <p>UI Adjustment, fix audio output, Playlist reorder, and more.</p>
                <ul>
                    <li>Audio output device selection not respected</li>
                    <li>Playlist reorder moves item one position too far when dragging down</li>
                    <li>Dragging a track from the library to a playlist sidebar item did nothing</li>
                    <li>Lyrics text stays white in light mode</li>
                </ul>
            </description>
        </release>
        <release version="0.1.0" date="2026-05-07">
            <url type="details">https://github.com/nokarin-dev/aqloss/releases/tag/v0.1.0</url>
            <description>
                <p>Initial release Aqloss</p>
            </description>
        </release>
    </releases>

    <content_rating type="oars-1.1" />
</component>